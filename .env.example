# ============================================================
# AG Dental Lab — Environment Variables
# Copy to .env and fill in real values. NEVER commit .env.
# ============================================================

# --- Database (Supabase Postgres) -----------------------------------
# Pooled connection (PgBouncer) for the app runtime.
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# Direct connection for Prisma migrations.
DIRECT_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# --- Auth.js / NextAuth --------------------------------------------
# Generate: `npx auth secret` or `openssl rand -base64 32`
AUTH_SECRET="replace-with-32-byte-random-secret"
AUTH_URL="http://localhost:3000"
# Trust the host header (needed on Vercel / proxied deploys)
AUTH_TRUST_HOST="true"

# --- The single admin account (seeded) -----------------------------
ADMIN_EMAIL="owner@agdentallab.com"
ADMIN_PASSWORD="change-this-strong-password"

# --- Upstash Redis (rate limiting + caching) -----------------------
UPSTASH_REDIS_REST_URL="https://[your-db].upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"

# --- Object Storage (Cloudflare R2 or AWS S3) ----------------------
# R2 example: endpoint = https://<accountid>.r2.cloudflarestorage.com
S3_ENDPOINT="https://<accountid>.r2.cloudflarestorage.com"
S3_REGION="auto"
S3_ACCESS_KEY_ID="your-access-key"
S3_SECRET_ACCESS_KEY="your-secret-key"
S3_BUCKET="ag-dental-lab"
# Public base URL used to serve uploaded images (R2 public bucket / CDN).
S3_PUBLIC_URL="https://pub-xxxx.r2.dev"

# --- Sentry (optional; leave blank to disable) ---------------------
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""

# --- App ------------------------------------------------------------
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
