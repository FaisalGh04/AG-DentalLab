// AG Dental Lab — Prisma schema
// PostgreSQL (Supabase). Run `pnpm db:push` or `pnpm db:migrate`.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ------------------------------------------------------------------
// Single admin (the lab owner). No multi-admin, no doctor accounts.
// ------------------------------------------------------------------
model Admin {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("admins")
}

// ------------------------------------------------------------------
// A case's lifecycle is defined by its selected production Collection and the
// ordered Stages within it (see src/lib/production-templates.ts). There is no
// fixed status enum anymore — progress is a stage id within a collection.
// ------------------------------------------------------------------

enum CaseCategory {
  IMPLANT
  C_AND_B
  PRESSABLE_CERAMIC
  VACUUM_FORMER
  SPECIAL_TRAY
  RESIN_MODEL
  EXTERNAL_LABORATORY_SERVICES
  DENTAL_EQUIPMENT
  GYPSUM_MODEL
  FLEX_DENTURE
}

// ------------------------------------------------------------------
// A dental case. Doctors track these by public tracking ID only.
// ------------------------------------------------------------------
model PatientCase {
  id                     String       @id @default(cuid())
  trackingId             String       @unique @map("tracking_id")
  patientFirstName       String       @map("patient_first_name")
  patientLastName        String       @map("patient_last_name")
  // Denormalized lowercased full name for fast, case-insensitive lookup.
  patientFullNameNorm    String       @map("patient_full_name_norm")
  doctorName             String       @map("doctor_name")
  caseType               String       @map("case_type")
  category               CaseCategory
  // Selected production template (src/lib/production-templates.ts). Both nullable:
  // a case can exist before a collection/stage is chosen.
  collectionId           String?      @map("collection_id")
  currentStageId         String?      @map("current_stage_id")
  // Stage ids hidden for THIS case (excluded from its stepper). Default: none.
  hiddenStageIds         String[]     @default([]) @map("hidden_stage_ids")
  // Derived + persisted whenever collection/stage/hidden changes: true when the
  // current stage is the last VISIBLE stage. Drives archive + dashboard queries.
  isCompleted            Boolean      @default(false) @map("is_completed")
  estimatedCompletionDate DateTime?   @map("estimated_completion_date")
  notes                  String?
  createdAt              DateTime     @default(now()) @map("created_at")
  updatedAt              DateTime     @updatedAt @map("updated_at")

  progress CaseProgress[]
  images   CaseImage[]

  // Indexes tuned for the two hot paths: public tracking lookup + admin list.
  @@index([patientFullNameNorm])
  @@index([trackingId])
  @@index([isCompleted])
  @@index([createdAt])
  @@index([doctorName])
  @@map("patient_cases")
}

// ------------------------------------------------------------------
// Ordered production steps for a case. Admin adds/updates freely.
// ------------------------------------------------------------------
model CaseProgress {
  id          String   @id @default(cuid())
  caseId      String   @map("case_id")
  stepTitle   String   @map("step_title")
  description String?
  completed   Boolean  @default(false)
  // Which production stage this step belongs to — a stage id from the case's
  // collection (src/lib/production-templates.ts). Nullable: steps added before a
  // collection/stage was chosen are treated as "General" / unscoped. Mirrors
  // CaseImage.stageId so the case detail + tracker can scope steps per stage.
  stageId     String?  @map("stage_id")
  order       Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  case PatientCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId])
  @@index([caseId, stageId])
  @@map("case_progress")
}

// ------------------------------------------------------------------
// Uploaded case images (stored in R2/S3; only the URL is persisted).
// ------------------------------------------------------------------
model CaseImage {
  id        String      @id @default(cuid())
  caseId    String      @map("case_id")
  imageUrl  String      @map("image_url")
  key       String?     // storage object key, for deletion
  caption   String?
  // Which production stage this image documents — a stage id from the case's
  // collection (src/lib/production-templates.ts). Nullable: images uploaded
  // before a collection/stage was chosen are treated as "General".
  stageId   String?     @map("stage_id")
  createdAt DateTime    @default(now()) @map("created_at")

  case PatientCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId])
  @@index([caseId, stageId])
  @@map("case_images")
}

// ------------------------------------------------------------------
// The SINGLE SOURCE OF TRUTH for per-stage Quick-Add step chips. Seeded once
// from production-templates.ts's built-in step lists (see the accompanying
// migration), then fully admin-editable: add / rename (labelEn+labelAr) / delete
// any chip. Collections & Stages themselves stay static in production-templates.ts
// (id/en/ar) — only these Quick-Add step LISTS are DB-backed now.
//
// Scoped to a (collectionId, stageId); a chip is shared by every case using that
// collection+stage. Editing/deleting a chip only changes the suggestion list going
// forward — it never touches CaseProgress rows already logged on real cases.
// ------------------------------------------------------------------
model StageQuickAddStep {
  id           String   @id @default(cuid())
  collectionId String   @map("collection_id")
  stageId      String   @map("stage_id")
  labelEn      String   @map("label_en")
  labelAr      String   @map("label_ar")
  order        Int      @default(0)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // One chip per English label within a stage (prevents duplicate chips).
  @@unique([collectionId, stageId, labelEn])
  @@index([collectionId, stageId])
  @@map("stage_quick_add_steps")
}
