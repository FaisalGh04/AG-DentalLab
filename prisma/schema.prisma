// AG Dental Lab — Prisma schema
// PostgreSQL (Supabase). Run `pnpm db:push` or `pnpm db:migrate`.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ------------------------------------------------------------------
// Single admin (the lab owner). No multi-admin, no doctor accounts.
// ------------------------------------------------------------------
model Admin {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("admins")
}

// ------------------------------------------------------------------
// A case's lifecycle is defined by its selected production Collection and the
// ordered Stages within it (see src/lib/production-templates.ts). There is no
// fixed status enum anymore — progress is a stage id within a collection.
// ------------------------------------------------------------------

enum CaseCategory {
  IMPLANT
  C_AND_B
  PRESSABLE_CERAMIC
  VACUUM_FORMER
  SPECIAL_TRAY
  RESIN_MODEL
  EXTERNAL_LABORATORY_SERVICES
  DENTAL_EQUIPMENT
  GYPSUM_MODEL
  FLEX_DENTURE
}

// ------------------------------------------------------------------
// A dental case. Doctors track these by public tracking ID only.
// ------------------------------------------------------------------
model PatientCase {
  id                     String       @id @default(cuid())
  trackingId             String       @unique @map("tracking_id")
  patientFirstName       String       @map("patient_first_name")
  patientLastName        String       @map("patient_last_name")
  // Denormalized lowercased full name for fast, case-insensitive lookup.
  patientFullNameNorm    String       @map("patient_full_name_norm")
  doctorName             String       @map("doctor_name")
  caseType               String       @map("case_type")
  category               CaseCategory
  // Selected production template (src/lib/production-templates.ts). Both nullable:
  // a case can exist before a collection/stage is chosen.
  collectionId           String?      @map("collection_id")
  currentStageId         String?      @map("current_stage_id")
  // Stage ids hidden for THIS case (excluded from its stepper). Default: none.
  hiddenStageIds         String[]     @default([]) @map("hidden_stage_ids")
  // Derived + persisted whenever collection/stage/hidden changes: true when the
  // current stage is the last VISIBLE stage. Drives archive + dashboard queries.
  isCompleted            Boolean      @default(false) @map("is_completed")
  estimatedCompletionDate DateTime?   @map("estimated_completion_date")
  notes                  String?
  createdAt              DateTime     @default(now()) @map("created_at")
  updatedAt              DateTime     @updatedAt @map("updated_at")

  progress CaseProgress[]
  images   CaseImage[]

  // Indexes tuned for the two hot paths: public tracking lookup + admin list.
  @@index([patientFullNameNorm])
  @@index([trackingId])
  @@index([isCompleted])
  @@index([createdAt])
  @@index([doctorName])
  @@map("patient_cases")
}

// ------------------------------------------------------------------
// Ordered production steps for a case. Admin adds/updates freely.
// ------------------------------------------------------------------
model CaseProgress {
  id          String   @id @default(cuid())
  caseId      String   @map("case_id")
  stepTitle   String   @map("step_title")
  description String?
  completed   Boolean  @default(false)
  // Which production stage this step belongs to — a stage id from the case's
  // collection (src/lib/production-templates.ts). Nullable: steps added before a
  // collection/stage was chosen are treated as "General" / unscoped. Mirrors
  // CaseImage.stageId so the case detail + tracker can scope steps per stage.
  stageId     String?  @map("stage_id")
  order       Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  case PatientCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId])
  @@index([caseId, stageId])
  @@map("case_progress")
}

// ------------------------------------------------------------------
// Uploaded case images (stored in R2/S3; only the URL is persisted).
// ------------------------------------------------------------------
model CaseImage {
  id        String      @id @default(cuid())
  caseId    String      @map("case_id")
  // Storage object key. Images are NEVER served by a public bucket URL — the
  // key is signed on demand into a short-lived URL via /api/images/[id] (S-M3).
  key       String
  caption   String?
  // Which production stage this image documents — a stage id from the case's
  // collection (src/lib/production-templates.ts). Nullable: images uploaded
  // before a collection/stage was chosen are treated as "General".
  stageId   String?     @map("stage_id")
  createdAt DateTime    @default(now()) @map("created_at")

  case PatientCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId])
  @@index([caseId, stageId])
  @@map("case_images")
}

// ------------------------------------------------------------------
// The SINGLE SOURCE OF TRUTH for per-stage Quick-Add step chips. Seeded once
// from production-templates.ts's built-in step lists (see the accompanying
// migration), then fully admin-editable: add / rename (labelEn+labelAr) / delete
// any chip. Collections & Stages themselves stay static in production-templates.ts
// (id/en/ar) — only these Quick-Add step LISTS are DB-backed now.
//
// Scoped to a (collectionId, stageId); a chip is shared by every case using that
// collection+stage. Editing/deleting a chip only changes the suggestion list going
// forward — it never touches CaseProgress rows already logged on real cases.
// ------------------------------------------------------------------
model StageQuickAddStep {
  id           String   @id @default(cuid())
  collectionId String   @map("collection_id")
  stageId      String   @map("stage_id")
  labelEn      String   @map("label_en")
  labelAr      String   @map("label_ar")
  order        Int      @default(0)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Phase 1 (case-group migration): nullable link to the DB-backed CaseStage that
  // (collectionId, stageId) resolves to. Additive — the string columns above stay
  // the source of truth until a later phase re-parents these chips fully.
  caseStageId  String?    @map("case_stage_id")
  caseStage    CaseStage? @relation(fields: [caseStageId], references: [id], onDelete: Cascade)

  // One chip per English label within a stage (prevents duplicate chips).
  @@unique([collectionId, stageId, labelEn])
  @@index([collectionId, stageId])
  @@index([caseStageId])
  @@map("stage_quick_add_steps")
}

// ------------------------------------------------------------------
// DB-backed case lifecycle taxonomy (Phase 1 of the case-group migration).
// Replaces the static PRODUCTION_COLLECTIONS in src/lib/production-templates.ts,
// preserving every id so live case data keeps resolving:
//   - a "collection" becomes a CaseStageSet (id = the legacy collection kebab id,
//     which PatientCase.collection_id points at)
//   - a CaseGroup is the new parent (Zirconia C&B, Implant, ...) with a Digital
//     and/or Regular stage-set (independent type axis; <= 1 set per type)
//   - a CaseStage keeps stage_key = the legacy stage id (what current_stage_id,
//     hidden_stage_ids, CaseProgress.stage_id and CaseImage.stage_id resolve to)
// Additive only in Phase 1: seeded to mirror the static config, the app does not
// read these tables yet.
// ------------------------------------------------------------------

enum CaseWorkflowType {
  REGULAR
  DIGITAL
}

model CaseGroup {
  id        String         @id @default(cuid())
  labelEn   String         @map("label_en")
  labelAr   String         @map("label_ar")
  order     Int            @default(0)
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @updatedAt      @map("updated_at")

  stageSets CaseStageSet[]

  @@index([order])
  @@map("case_groups")
}

model CaseStageSet {
  // id has NO @default — seeded with the legacy collection kebab id so that
  // PatientCase.collection_id keeps resolving. Admin-created sets get a cuid.
  id        String           @id
  groupId   String           @map("group_id")
  group     CaseGroup        @relation(fields: [groupId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  type      CaseWorkflowType
  labelEn   String           @map("label_en")
  labelAr   String           @map("label_ar")
  order     Int              @default(0)
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt      @map("updated_at")

  stages CaseStage[]

  // A group has at most one Regular and one Digital stage-set.
  @@unique([groupId, type])
  @@index([groupId])
  @@map("case_stage_sets")
}

model CaseStage {
  id         String           @id @default(cuid())
  stageSetId String           @map("stage_set_id")
  stageSet   CaseStageSet     @relation(fields: [stageSetId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  // stage_key = the legacy stage id, unique within its set — what live case data
  // (current_stage_id, hidden_stage_ids, CaseProgress/CaseImage.stage_id) resolves to.
  stageKey   String           @map("stage_key")
  labelEn    String           @map("label_en")
  labelAr    String           @map("label_ar")
  order      Int              @default(0)
  createdAt  DateTime         @default(now()) @map("created_at")
  updatedAt  DateTime         @updatedAt      @map("updated_at")

  quickAddSteps StageQuickAddStep[]

  @@unique([stageSetId, stageKey])
  @@index([stageSetId, order])
  @@map("case_stages")
}

// ------------------------------------------------------------------
// Public "Our Work" portfolio — an admin-managed showcase for the landing page.
// Deliberately SEPARATE from PatientCase/CaseImage: no patient data, its own
// taxonomy (PortfolioFolder, matching the landing folders), and its images are
// public marketing assets (not the private, signed patient-case images).
// ------------------------------------------------------------------

// DB-backed portfolio folder (Phase C: this replaces the old PortfolioFolder
// enum, which has been dropped). Bilingual display name + free ordering,
// admin-managed. Table stays `portfolio_folders` via @@map.
model PortfolioFolder {
  id        String   @id @default(cuid())
  labelEn   String   @map("label_en")
  labelAr   String   @map("label_ar")
  // Display order across the whole Work section (ascending).
  order     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  items PortfolioItem[]

  @@index([order])
  @@map("portfolio_folders")
}

// One showcased case: bilingual copy + a folder + display order, with one or
// more photos.
model PortfolioItem {
  id            String          @id @default(cuid())
  folderId      String          @map("folder_id")
  folder        PortfolioFolder @relation(fields: [folderId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  titleEn       String          @map("title_en")
  titleAr       String          @map("title_ar")
  descriptionEn String          @map("description_en")
  descriptionAr String          @map("description_ar")
  // Display order within its folder (ascending). Ties break by createdAt.
  order         Int             @default(0)
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")

  images PortfolioImage[]

  @@index([folderId, order])
  @@map("portfolio_items")
}

// A photo belonging to a PortfolioItem.
model PortfolioImage {
  id        String   @id @default(cuid())
  itemId    String   @map("item_id")
  // Storage object key (R2/S3) for admin-uploaded photos. For assets migrated
  // from the original static gallery this holds the existing /public path
  // (e.g. /images/gallery/x.jpeg) until a later phase moves serving to R2.
  key       String
  // Intrinsic pixel size, captured at upload — the zoom lightbox needs the true
  // aspect ratio to lay out non-4:3 photos.
  width     Int
  height    Int
  // Display order within the item (ascending), for multi-photo items.
  order     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  item PortfolioItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId, order])
  @@map("portfolio_images")
}
